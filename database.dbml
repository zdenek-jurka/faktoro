// Database schema for Faktoro app
// Generated from WatermelonDB schema version 52
// Syntax: DBML (Database Markup Language) - https://www.dbml.org/docs/

Project faktoro {
  database_type: 'SQLite'
  Note: 'Time tracking and client management application'
}

// Application settings - singleton table for app configuration
Table app_settings {
  id string [pk, note: 'WatermelonDB auto-generated ID']
  language string [not null, note: 'Current app language (en, cs)']
  default_billing_interval number [null, note: 'Default billing interval in minutes for new clients']
  timer_soft_limit_enabled boolean [null, note: 'Whether the global soft timer safety limit is enabled']
  timer_soft_limit_minutes number [null, note: 'Soft timer safety limit in minutes']
  timer_hard_limit_enabled boolean [null, note: 'Whether the global hard timer safety limit is enabled']
  timer_hard_limit_minutes number [null, note: 'Hard timer safety limit in minutes']
  default_company_registry string [null, note: 'Default company registry provider key']
  is_vat_payer boolean [not null, default: false, note: 'Whether invoice company is VAT payer - makes invoice_vat_number required']

  // Invoice company information
  invoice_company_name string [null]
  invoice_address string [null]
  invoice_street2 string [null, note: 'Optional second line for invoice street address']
  invoice_city string [null]
  invoice_postal_code string [null]
  invoice_country string [null]
  invoice_company_id string [null, note: 'Company registration number (IČO)']
  invoice_vat_number string [null, note: 'VAT number (DIČ)']
  invoice_registration_note string [null, note: 'Registry or other business registration note shown on invoices']
  invoice_email string [null]
  invoice_phone string [null]
  invoice_website string [null]
  invoice_bank_account string [null]
  invoice_iban string [null]
  invoice_swift string [null]
  invoice_logo_uri string [null]
  default_invoice_currency string [null, note: 'Default currency code used when creating new invoices (e.g. CZK, EUR)']
  default_invoice_vat_code_id string [null, note: 'Default VAT code used for new invoice items and new price list items']
  default_invoice_payment_method string [null, note: 'Default payment method for new invoices']
  default_invoice_due_days number [null, note: 'Default invoice due period in days']
  invoice_qr_type string [null, note: 'Invoice payment QR type: none/spayd/epc/swiss']
  invoice_default_export_format string [null, note: 'Default invoice XML export format: none/isdoc/peppol/xrechnung']
  invoice_series_prefix string [null]
  invoice_series_pattern string [null]
  invoice_series_next_number number [null]
  invoice_series_padding number [null]
  invoice_series_per_device boolean [null]
  invoice_series_device_code string [null]
  timesheet_series_prefix string [null]
  timesheet_series_pattern string [null]
  timesheet_series_next_number number [null]
  timesheet_series_padding number [null]
  timesheet_series_per_device boolean [null]
  timesheet_series_device_code string [null]

  app_lock_enabled boolean [null, note: 'Whether app-level lock is enabled']
  app_lock_biometric_enabled boolean [null, note: 'Whether biometric unlock is enabled when available']
  app_lock_grace_period_seconds number [null, note: 'Grace period before relocking after app returns from background']

  created_at number [not null, note: 'Unix timestamp in milliseconds']
  updated_at number [not null, note: 'Unix timestamp in milliseconds']

  Note: 'Stores global application settings and invoice company details'
}

// Generic key/value configuration storage
Table config_storage {
  id string [pk, note: 'WatermelonDB auto-generated ID']
  config_key string [not null, note: 'Configuration key']
  config_value string [not null, note: 'Configuration value']
  created_at number [not null, note: 'Unix timestamp in milliseconds']
  updated_at number [not null, note: 'Unix timestamp in milliseconds']

  Indexes {
    config_key [name: 'idx_config_storage_config_key']
  }

  Note: 'General-purpose device-local key/value storage; also stores sync identity under device_sync.* keys'
}

Table currency_setting {
  id string [pk, note: 'WatermelonDB auto-generated ID']
  code string [not null, note: 'ISO 4217 currency code, e.g. EUR or CZK']
  prefix string [null, note: 'String rendered before the formatted numeric amount']
  suffix string [null, note: 'String rendered after the formatted numeric amount']
  sort_order number [not null, note: 'Manual ordering for currency pickers']
  is_active boolean [not null, default: true, note: 'Whether the currency is available for new selections']
  created_at number [not null, note: 'Unix timestamp in milliseconds']
  updated_at number [not null, note: 'Unix timestamp in milliseconds']

  Indexes {
    code [name: 'idx_currency_setting_code']
  }

  Note: 'Shared business currency definitions used for pickers and amount formatting'
}

// Clients table - customers/companies
Table client {
  id string [pk, note: 'WatermelonDB auto-generated ID']
  name string [null, note: 'Client or company name']
  vat_number string [null, note: 'VAT number (DIČ) - required when is_vat_payer is true']
  company_id string [null, note: 'Company registration number (IČO) - indexed for search']
  is_company boolean [not null, default: false, note: 'Whether this is a company or individual']
  is_vat_payer boolean [not null, default: false, note: 'Whether client is VAT payer - makes vat_number required']
  email string [null]
  phone string [null]
  notes string [null, note: 'Additional notes about the client']
  export_language string [null, note: 'Optional export language override (en/cs), fallback to app language']
  invoice_qr_type string [null, note: 'Optional client-level QR override: none/spayd/epc/swiss; null = use global setting']
  invoice_default_export_format string [null, note: 'Optional client-level XML export override: none/isdoc/peppol/xrechnung; null = use global setting']
  invoice_payment_method string [null, note: 'Optional client-level payment method override; null = use app default']
  invoice_due_days number [null, note: 'Optional client-level due period override in days; null = use app default']

  // Billing settings
  billing_interval_enabled boolean [not null, default: false, note: 'Whether to round time entries by interval']
  billing_interval_minutes number [null, note: 'Rounding interval in minutes (e.g., 15, 30)']
  timer_limit_mode string [null, note: "Timer limit mode: 'default', 'custom', or 'disabled'"]
  timer_soft_limit_minutes number [null, note: 'Client-specific soft timer safety limit in minutes']
  timer_hard_limit_minutes number [null, note: 'Client-specific hard timer safety limit in minutes']
  is_archived boolean [not null, default: false, note: 'Soft delete flag used when client has linked records']

  created_at number [not null, note: 'Unix timestamp in milliseconds']
  updated_at number [not null, note: 'Unix timestamp in milliseconds']

  Indexes {
    company_id [name: 'idx_client_company_id']
  }

  Note: 'Stores client and company information for billing and time tracking'
}

// VAT code names (1 code has many VAT rates by validity ranges)
Table vat_code {
  id string [pk, note: 'WatermelonDB auto-generated ID']
  name string [not null, note: 'VAT code/rate name or bootstrap token (e.g. __FAKTORO_VAT__CZ__STANDARD__1__1)']
  country_code string [null, note: 'ISO 3166-1 alpha-2 country code when imported via bootstrap (e.g. CZ, DE)']
  created_at number [not null, note: 'Unix timestamp in milliseconds']
  updated_at number [not null, note: 'Unix timestamp in milliseconds']

  Note: 'Master table of VAT code names used by vat_rate'
}

// VAT rates with validity periods
Table vat_rate {
  id string [pk, note: 'WatermelonDB auto-generated ID']
  vat_code_id string [null, ref: > vat_code.id, note: 'Reference to VAT code (new model)']
  rate_percent number [not null, note: 'VAT percentage rate (0-100)']
  valid_from number [not null, note: 'Unix timestamp in milliseconds (start of validity); empty "valid from" in UI is stored as 0001-01-01 (from beginning)']
  valid_to number [null, note: 'Unix timestamp in milliseconds (end of validity, optional)']
  created_at number [not null, note: 'Unix timestamp in milliseconds']
  updated_at number [not null, note: 'Unix timestamp in milliseconds']

  Indexes {
    vat_code_id [name: 'idx_vat_rate_vat_code_id']
    valid_from [name: 'idx_vat_rate_valid_from']
    valid_to [name: 'idx_vat_rate_valid_to']
  }

  Note: '1:N rates by validity period for each VAT code name'
}

// Client addresses - billing, shipping, and other addresses
Table client_address {
  id string [pk, note: 'WatermelonDB auto-generated ID']
  client_id string [not null, ref: > client.id, note: 'Reference to parent client']
  type string [not null, note: "Address type: 'billing', 'shipping', or 'other'"]
  street string [not null]
  street2 string [null, note: 'Optional second line for street address']
  city string [not null]
  postal_code string [not null]
  country string [not null]
  is_default boolean [not null, default: false, note: 'Whether this is the default address for the client']

  created_at number [not null, note: 'Unix timestamp in milliseconds']
  updated_at number [not null, note: 'Unix timestamp in milliseconds']

  Indexes {
    client_id [name: 'idx_client_address_client_id']
  }

  Note: 'Multiple addresses per client for billing, shipping, etc.'
}

// Time tracking entries
Table time_entry {
  id string [pk, note: 'WatermelonDB auto-generated ID']
  client_id string [not null, ref: > client.id, note: 'Client this time entry is for']
  description string [null, note: 'Optional activity description']
  start_time number [not null, note: 'Unix timestamp in milliseconds when timer started']
  end_time number [null, note: 'Unix timestamp in milliseconds when timer stopped']
  duration number [null, note: 'Total duration in seconds (excluding paused time)']

  // Timer state
  is_running boolean [not null, default: false, note: 'Whether timer is currently running']
  is_paused boolean [not null, default: false, note: 'Whether timer is paused']
  paused_at number [null, note: 'Unix timestamp in milliseconds when timer was paused']
  total_paused_duration number [null, note: 'Total paused duration in seconds']
  running_device_id string [null, note: 'Device ID where the timer is currently running']
  running_device_name string [null, note: 'Device name where the timer is currently running']
  timesheet_id string [null, ref: > timesheet.id, note: 'Optional reference to exported timesheet']
  timesheet_duration number [null, note: 'Frozen rounded duration in seconds captured when the timesheet was generated']

  // Price list integration
  price_list_item_id string [null, ref: > price_list_item.id, note: 'Optional reference to price list item']
  rate number [null, note: 'Rate used at time of entry creation (preserves historical pricing)']
  rate_currency string [null, note: 'Currency code of the stored historical rate']
  timer_soft_limit_minutes number [null, note: 'Resolved soft timer safety limit stored on the entry in minutes']
  timer_hard_limit_minutes number [null, note: 'Resolved hard timer safety limit stored on the entry in minutes']
  soft_limit_notified_at number [null, note: 'Unix timestamp in milliseconds when the soft limit warning was shown']

  created_at number [not null, note: 'Unix timestamp in milliseconds']
  updated_at number [not null, note: 'Unix timestamp in milliseconds']

  Indexes {
    client_id [name: 'idx_time_entry_client_id']
    is_running [name: 'idx_time_entry_is_running']
    is_paused [name: 'idx_time_entry_is_paused']
    running_device_id [name: 'idx_time_entry_running_device_id']
    timesheet_id [name: 'idx_time_entry_timesheet_id']
    price_list_item_id [name: 'idx_time_entry_price_list_item_id']
  }

  Note: 'Time tracking entries with support for pause/resume functionality'
}

// Timesheets - exported periods of client time entries
Table timesheet {
  id string [pk, note: 'WatermelonDB auto-generated ID']
  client_id string [not null, ref: > client.id, note: 'Client owner of this timesheet']
  period_type string [not null, note: 'Selected period kind: all/custom/this_month/last_month/this_week/last_week/last_7_days']
  period_from number [not null, note: 'Unix timestamp in milliseconds - inclusive period start']
  period_to number [not null, note: 'Unix timestamp in milliseconds - inclusive period end']
  timesheet_number string [null, note: 'Generated timesheet identifier from numbering series']
  label string [null, note: 'Optional custom label of the generated timesheet']
  created_at number [not null, note: 'Unix timestamp in milliseconds']
  updated_at number [not null, note: 'Unix timestamp in milliseconds']

  Indexes {
    client_id [name: 'idx_timesheet_client_id']
    period_from [name: 'idx_timesheet_period_from']
    period_to [name: 'idx_timesheet_period_to']
    timesheet_number [name: 'idx_timesheet_timesheet_number']
  }

  Note: 'Groups finalized time entries for a client and period'
}

// Invoices - issued billing documents
Table invoice {
  id string [pk, note: 'WatermelonDB auto-generated ID']
  client_id string [not null, ref: > client.id, note: 'Billed client']
  invoice_number string [not null, note: 'Invoice number visible to customer']
  buyer_reference string [null, note: 'Buyer reference / Leitweg-ID for structured invoice routing']
  issued_at number [not null, note: 'Issue date (Unix ms)']
  taxable_at number [null, note: 'Taxable supply date / DUZP (Unix ms), required for VAT payer']
  due_at number [null, note: 'Due date (Unix ms)']
  currency string [not null, note: 'Currency code (e.g. CZK, EUR)']
  payment_method string [null, note: 'Optional payment method (e.g. transfer, cash)']
  status string [not null, note: 'Invoice state (issued, voided_before_delivery, canceled_by_correction)']
  header_note string [null, note: 'Optional note at document header']
  footer_note string [null, note: 'Optional note/footer text']
  seller_snapshot_json string [null, note: 'JSON snapshot of seller details at issue time, including bank account and logo URI']
  buyer_snapshot_json string [null, note: 'JSON snapshot of buyer details at issue time, including preferred invoice address']
  last_exported_at number [null, note: 'Unix timestamp in milliseconds of the last successful export or save action']
  corrected_invoice_id string [null, ref: > invoice.id, note: 'Original invoice id if this invoice is a correction document']
  correction_kind string [null, note: 'Correction kind (currently cancellation)']
  cancellation_reason string [null, note: 'User-entered reason for voiding or cancellation']
  subtotal number [not null, note: 'Subtotal amount']
  total number [not null, note: 'Final total amount']
  created_at number [not null, note: 'Unix timestamp in milliseconds']
  updated_at number [not null, note: 'Unix timestamp in milliseconds']

  Indexes {
    client_id [name: 'idx_invoice_client_id']
    invoice_number [name: 'idx_invoice_invoice_number']
    issued_at [name: 'idx_invoice_issued_at']
    taxable_at [name: 'idx_invoice_taxable_at']
    last_exported_at [name: 'idx_invoice_last_exported_at']
    corrected_invoice_id [name: 'idx_invoice_corrected_invoice_id']
    status [name: 'idx_invoice_status']
  }

  Note: 'Issued invoice headers'
}

// Invoice line items
Table invoice_item {
  id string [pk, note: 'WatermelonDB auto-generated ID']
  invoice_id string [not null, ref: > invoice.id, note: 'Parent invoice']
  source_kind string [not null, note: 'timesheet | price_list | manual']
  source_id string [null, note: 'Optional source record id (timesheet or price list item)']
  description string [not null, note: 'Line item label shown on invoice']
  quantity number [not null, note: 'Quantity value']
  unit string [null, note: 'Optional quantity unit']
  unit_price number [not null, note: 'Unit price']
  total_price number [not null, note: 'Line total']
  vat_code_id string [null, ref: > vat_code.id, note: 'Optional reference to VAT code used for this line']
  vat_rate number [null, note: 'Optional VAT rate percent']
  created_at number [not null, note: 'Unix timestamp in milliseconds']
  updated_at number [not null, note: 'Unix timestamp in milliseconds']

  Indexes {
    invoice_id [name: 'idx_invoice_item_invoice_id']
    source_id [name: 'idx_invoice_item_source_id']
    vat_code_id [name: 'idx_invoice_item_vat_code_id']
  }

  Note: 'Invoice lines, optionally linked to timesheet or price list sources'
}

// Price list items - services and products with default pricing
Table price_list_item {
  id string [pk, note: 'WatermelonDB auto-generated ID']
  name string [not null, note: 'Service/product name']
  description string [null, note: 'Optional description of the service']
  default_price number [not null, note: 'Default price/rate for this item']
  default_price_currency string [null, note: 'Currency code used for the default price']
  unit string [not null, note: 'Unit of measurement (hour, piece, project, day, custom)']
  vat_code_id string [null, ref: > vat_code.id, note: 'Optional reference to VAT code']
  vat_name string [null, note: 'Optional VAT code name from VAT settings']
  is_active boolean [not null, default: true, note: 'Whether this item is active (soft delete)']

  created_at number [not null, note: 'Unix timestamp in milliseconds']
  updated_at number [not null, note: 'Unix timestamp in milliseconds']

  Indexes {
    vat_code_id [name: 'idx_price_list_item_vat_code_id']
  }

  Note: 'Catalog of billable services and products with default pricing'
}

// Client-specific price overrides
Table client_price_override {
  id string [pk, note: 'WatermelonDB auto-generated ID']
  client_id string [not null, ref: > client.id, note: 'Client for this price override']
  price_list_item_id string [not null, ref: > price_list_item.id, note: 'Price list item being overridden']
  custom_price number [not null, note: 'Custom price for this client']
  custom_price_currency string [null, note: 'Currency code inherited from the linked price list item']

  created_at number [not null, note: 'Unix timestamp in milliseconds']
  updated_at number [not null, note: 'Unix timestamp in milliseconds']

  Indexes {
    client_id [name: 'idx_client_price_override_client_id']
    price_list_item_id [name: 'idx_client_price_override_price_list_item_id']
  }

  Note: 'Client-specific pricing that overrides default prices from price list'
}

// Offline operation queue for multi-device synchronization
Table sync_operation {
  id string [pk, note: 'WatermelonDB auto-generated ID']
  op_id string [not null, note: 'Operation ID (idempotency key)']
  table_name string [not null, note: 'Target table name']
  record_id string [not null, note: 'Target record ID']
  operation_type string [not null, note: "Operation type: 'insert', 'update', 'delete'"]
  payload_json string [null, note: 'Serialized operation payload']
  base_version number [null, note: 'Base record version used for conflict detection']
  is_synced boolean [not null, default: false, note: 'Whether operation has been acknowledged by server']
  retry_count number [not null, default: 0, note: 'Number of retry attempts']
  synced_at number [null, note: 'Unix timestamp in milliseconds when sync succeeded']
  created_at number [not null, note: 'Unix timestamp in milliseconds']
  updated_at number [not null, note: 'Unix timestamp in milliseconds']

  Indexes {
    op_id [name: 'idx_sync_operation_op_id']
    table_name [name: 'idx_sync_operation_table_name']
    record_id [name: 'idx_sync_operation_record_id']
  }

  Note: 'Queue of local operations waiting for server synchronization'
}

// Conflict records for user-assisted conflict resolution
Table sync_conflict {
  id string [pk, note: 'WatermelonDB auto-generated ID']
  table_name string [not null, note: 'Conflicted table name']
  record_id string [not null, note: 'Conflicted record ID']
  conflict_type string [not null, note: "Conflict type (e.g. update/update, delete/update)"]
  base_payload_json string [null, note: 'Base version payload']
  local_payload_json string [null, note: 'Local payload']
  remote_payload_json string [null, note: 'Remote payload']
  conflicting_fields_json string [null, note: 'List/details of conflicting fields']
  resolution_json string [null, note: 'User-selected resolution payload']
  status string [not null, note: "Conflict status: 'pending', 'resolved', 'applied'"]
  resolved_at number [null, note: 'Unix timestamp in milliseconds when resolved']
  created_at number [not null, note: 'Unix timestamp in milliseconds']
  updated_at number [not null, note: 'Unix timestamp in milliseconds']

  Indexes {
    table_name [name: 'idx_sync_conflict_table_name']
    record_id [name: 'idx_sync_conflict_record_id']
    status [name: 'idx_sync_conflict_status']
  }

  Note: 'Stores sync conflicts for explicit user resolution in the app UI'
}

// Enums
Enum AddressType {
  billing
  shipping
  other
}
