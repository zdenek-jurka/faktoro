{
  "expo": {
    "name": "Faktoro",
    "slug": "faktoro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "faktoro",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/ios-app-icon.png",
      "supportsTablet": true,
      "bundleIdentifier": "cz.jware.faktoro",
      "infoPlist": {
        "UIDesignRequiresCompatibility": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": true,
      "package": "cz.jware.faktoro",
      "permissions": ["android.permission.CAMERA", "android.permission.RECORD_AUDIO"]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-widgets",
        {
          "widgets": [
            {
              "name": "TimerWidget",
              "displayName": "Faktoro Timer",
              "description": "Sleduj a ovládej běžící timer přímo z plochy.",
              "supportedFamilies": ["systemSmall", "systemMedium"],
              "contentMarginsDisabled": false
            }
          ],
          "groupIdentifier": "group.cz.jware.faktoro",
          "bundleIdentifier": "cz.jware.faktoro.ExpoWidgetsTarget"
        }
      ],
      "./plugins/with-android-date-version-code.js",
      "./plugins/with-custom-android-signing.js",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-screen.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#E6F4FE",
          "dark": {
            "image": "./assets/images/splash-screen-dark.png",
            "backgroundColor": "#11181C"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Faktoro to access your camera for scanning recovery QR codes."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Faktoro to access your photos so you can choose a logo for invoices."
        }
      ],
      "expo-sqlite",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-image",
      "expo-localization",
      "expo-sharing",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "ExpoWidgetsTarget",
                  "bundleIdentifier": "cz.jware.faktoro.ExpoWidgetsTarget",
                  "entitlements": {
                    "com.apple.security.application-groups": ["group.cz.jware.faktoro"]
                  }
                }
              ]
            }
          }
        },
        "projectId": "52004dde-33ea-4b28-9639-e6dc989fdfb6"
      },
      "router": {}
    }
  }
}
