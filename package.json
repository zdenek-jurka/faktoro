{
  "name": "faktoro",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "clean-android": "cd ./android && ./gradlew clean",
    "build-android-release": "cd ./android && rm -rf app/.cxx && ./gradlew clean :app:bundleRelease",
    "build-android-release-apk": "cd ./android && rm -rf app/.cxx && ./gradlew clean :app:assembleRelease",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "audit:colors": "node ./scripts/audit-colors.js",
    "prepare": "husky",
    "i18n:generate": "typesafe-i18n --no-watch",
    "postinstall": "typesafe-i18n --no-watch && patch-package",
    "check:cng": "node ./scripts/check-cng.js"
  },
  "dependencies": {
    "@expo/ui": "~55.0.5",
    "@expo/vector-icons": "^15.0.3",
    "@formatjs/intl-getcanonicallocales": "^3.2.1",
    "@formatjs/intl-locale": "^5.2.1",
    "@formatjs/intl-pluralrules": "^6.2.2",
    "@noble/ciphers": "^1.3.0",
    "@nozbe/watermelondb": "^0.28.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-picker/picker": "2.11.4",
    "@react-native-segmented-control/segmented-control": "2.5.7",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/drawer": "^7.5.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@xmldom/xmldom": "0.8.11",
    "expo": "^55.0.6",
    "expo-camera": "~55.0.10",
    "expo-clipboard": "~55.0.9",
    "expo-constants": "~55.0.9",
    "expo-crypto": "~55.0.10",
    "expo-dev-client": "~55.0.18",
    "expo-document-picker": "~55.0.9",
    "expo-file-system": "~55.0.11",
    "expo-font": "~55.0.4",
    "expo-glass-effect": "~55.0.8",
    "expo-haptics": "~55.0.9",
    "expo-image": "~55.0.6",
    "expo-image-picker": "~55.0.13",
    "expo-linear-gradient": "~55.0.9",
    "expo-linking": "~55.0.8",
    "expo-local-authentication": "~55.0.9",
    "expo-localization": "~55.0.9",
    "expo-print": "~55.0.9",
    "expo-router": "~55.0.7",
    "expo-secure-store": "~55.0.9",
    "expo-sharing": "~55.0.14",
    "expo-splash-screen": "~55.0.12",
    "expo-sqlite": "~55.0.11",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.10",
    "expo-web-browser": "~55.0.10",
    "expo-widgets": "^55.0.4",
    "qrcode": "^1.5.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "typesafe-i18n": "^5.26.2",
    "xlsx": "^0.18.5",
    "xslt-processor": "5.0.5"
  },
  "devDependencies": {
    "@react-native-community/cli": "latest",
    "@react-native-community/cli-clean": "^20.1.3",
    "@types/react": "~19.2.10",
    "eas-cli": "^18.4.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "private": true,
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md}": [
      "prettier --write"
    ]
  }
}
